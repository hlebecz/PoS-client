<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<VBox xmlns="http://javafx.com/javafx/21"
      xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="kurs.client.ui.SaleController"
      spacing="16" fillWidth="true">

    <Label text="Продажи" styleClass="page-title"/>

    <TabPane fx:id="tabPane" tabClosingPolicy="UNAVAILABLE" VBox.vgrow="ALWAYS" styleClass="app-tab-pane">

        <Tab fx:id="createTab" text="Новая продажа">
            <HBox spacing="16" fillHeight="true">
                <padding><Insets top="14" right="0" bottom="0" left="0"/></padding>

                <!-- Остатки -->
                <VBox spacing="10" HBox.hgrow="ALWAYS" styleClass="card">
                    <Label text="Остатки в точке" styleClass="section-title"/>

                    <HBox fx:id="storePickerRow" spacing="8" alignment="CENTER_LEFT">
                        <Label text="Точка:"/>
                        <TextField fx:id="stockStoreField" prefWidth="180"
                                   editable="false" promptText="не выбрана"/>
                        <Button text="Выбрать" styleClass="btn-secondary"
                                onAction="#pickStockStore"/>
                    </HBox>

                    <TableView fx:id="stockTable" VBox.vgrow="ALWAYS">
                        <columns>
                            <TableColumn fx:id="colStockName"    text="Товар"/>
                            <TableColumn fx:id="colStockArticle" text="Артикул"  maxWidth="100"/>
                            <TableColumn fx:id="colStockPrice"   text="Цена BYN"   maxWidth="90"/>
                            <TableColumn fx:id="colStockQty"     text="Остаток"  maxWidth="80"/>
                        </columns>
                        <columnResizePolicy>
                            <TableView fx:constant="CONSTRAINED_RESIZE_POLICY"/>
                        </columnResizePolicy>
                    </TableView>

                    <HBox spacing="10" alignment="CENTER_LEFT" styleClass="action-toolbar">
                        <Label text="Кол-во:"/>
                        <TextField fx:id="addQtyField" text="1" prefWidth="64"/>
                        <Button text="+ В корзину" styleClass="btn-primary"
                                onAction="#handleAddFromStock"/>
                    </HBox>
                </VBox>

                <VBox spacing="10" prefWidth="340" minWidth="290" styleClass="card">
                    <Label text="Корзина" styleClass="section-title"/>

                    <TableView fx:id="cartTable" VBox.vgrow="ALWAYS">
                        <columns>
                            <TableColumn fx:id="colCartName"  text="Товар"/>
                            <TableColumn fx:id="colCartQty"   text="Кол." maxWidth="56"/>
                            <TableColumn fx:id="colCartPrice" text="BYN"    maxWidth="80"/>
                            <TableColumn fx:id="colCartDel"   text=""     maxWidth="44"/>
                        </columns>
                        <columnResizePolicy>
                            <TableView fx:constant="CONSTRAINED_RESIZE_POLICY"/>
                        </columnResizePolicy>
                    </TableView>

                    <Separator/>

                    <HBox alignment="CENTER" spacing="8">
                        <Label text="Итого:" styleClass="label-muted"/>
                        <Region HBox.hgrow="ALWAYS"/>
                        <Label fx:id="totalLabel"
                               style="-fx-font-size:18px;-fx-font-weight:bold;-fx-text-fill:#111827;"/>
                    </HBox>

                    <Label fx:id="saleStatusLabel" styleClass="error-label" wrapText="true"/>

                    <HBox spacing="8" alignment="CENTER_RIGHT">
                        <Button text="Очистить"       styleClass="btn-secondary" onAction="#handleClearCart"/>
                        <Button text="Провести"        styleClass="btn-success"   onAction="#handleConfirmSale"/>
                    </HBox>
                </VBox>
            </HBox>
        </Tab>

        <Tab fx:id="listTab" text="История">
            <VBox spacing="12" fillWidth="true">
                <padding><Insets top="14" right="0" bottom="0" left="0"/></padding>

                <HBox spacing="10" alignment="CENTER_LEFT" styleClass="action-toolbar">
                    <Label text="Магазин:"/>
                    <TextField fx:id="historyStoreField" prefWidth="180"
                               editable="false" promptText="не выбран"/>
                    <Button text="Выбрать"   styleClass="btn-secondary" onAction="#pickHistoryStore"/>
                    <Button text="Загрузить" styleClass="btn-primary"   onAction="#handleLoadHistory"/>
                </HBox>

                <TableView fx:id="historyTable" VBox.vgrow="ALWAYS">
                    <columns>
                        <TableColumn fx:id="colSaleId"  text="Номер"   maxWidth="100"/>
                        <TableColumn fx:id="colCashier" text="Кассир"/>
                        <TableColumn fx:id="colTotal"   text="Сумма BYN" maxWidth="100"/>
                        <TableColumn fx:id="colDate"    text="Дата"/>
                        <TableColumn fx:id="colReturn"  text="Возврат" maxWidth="76"/>
                    </columns>
                    <columnResizePolicy>
                        <TableView fx:constant="CONSTRAINED_RESIZE_POLICY"/>
                    </columnResizePolicy>
                </TableView>

                <HBox alignment="CENTER_RIGHT">
                    <Button fx:id="returnButton" text="Оформить возврат" styleClass="btn-danger"
                            onAction="#handleProcessReturn"/>
                </HBox>
            </VBox>
        </Tab>

    </TabPane>
</VBox>
