<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<VBox xmlns="http://javafx.com/javafx/21"
      xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="kurs.client.ui.ProductController"
      spacing="16" fillWidth="true">

    <Label text="Товары" styleClass="page-title"/>

    <TabPane fx:id="tabPane" tabClosingPolicy="UNAVAILABLE" VBox.vgrow="ALWAYS">
        <Tab fx:id="listTab" text="Список">
            <VBox spacing="10">
                <padding><Insets top="14" right="0" bottom="0" left="0"/></padding>
                <HBox spacing="10" alignment="CENTER_LEFT" styleClass="action-toolbar">
                    <Button text="Обновить" styleClass="btn-primary" onAction="#handleLoad"/>
                    <Separator orientation="VERTICAL"/>
                    <Button fx:id="editButton" text="Изменить" styleClass="btn-warning" onAction="#handleEdit"/>
                    <Button fx:id="deleteButton" text="Удалить" styleClass="btn-danger" onAction="#handleDelete"/>
                    <Separator orientation="VERTICAL"/>
                    <TextField fx:id="searchField" promptText="Поиск по артикулу..." prefWidth="200"/>
                    <Button text="Найти" styleClass="btn-primary" onAction="#handleSearch"/>
                </HBox>
                <TableView fx:id="productTable" VBox.vgrow="ALWAYS">
                    <columns>
                        <TableColumn fx:id="colName" text="Название" prefWidth="200"/>
                        <TableColumn fx:id="colArticle" text="Артикул" prefWidth="120"/>
                        <TableColumn fx:id="colPrice" text="Цена" prefWidth="100"/>
                        <TableColumn fx:id="colCreatedAt" text="Создан" prefWidth="150"/>
                    </columns>
                    <columnResizePolicy>
                        <TableView fx:constant="CONSTRAINED_RESIZE_POLICY"/>
                    </columnResizePolicy>
                </TableView>
            </VBox>
        </Tab>
        <Tab fx:id="createTab" text="Создать">
            <VBox spacing="14">
                <padding><Insets top="14" right="0" bottom="0" left="0"/></padding>
                <GridPane hgap="12" vgap="10">
                    <Label text="Название:" GridPane.columnIndex="0" GridPane.rowIndex="0"/>
                    <TextField fx:id="nameField" prefWidth="260"
                               GridPane.columnIndex="1" GridPane.rowIndex="0"/>
                    <Label text="Артикул:" GridPane.columnIndex="0" GridPane.rowIndex="1"/>
                    <TextField fx:id="articleField" prefWidth="260"
                               GridPane.columnIndex="1" GridPane.rowIndex="1"/>
                    <Label text="Цена:" GridPane.columnIndex="0" GridPane.rowIndex="2"/>
                    <TextField fx:id="priceField" prefWidth="260"
                               GridPane.columnIndex="1" GridPane.rowIndex="2"/>
                </GridPane>
                <Button text="Создать товар" styleClass="btn-success" onAction="#handleCreate"/>
                <Label fx:id="formError" styleClass="error-label"/>
            </VBox>
        </Tab>
        <Tab fx:id="updateTab" text="Обновить">
            <VBox spacing="14">
                <padding><Insets top="14" right="0" bottom="0" left="0"/></padding>
                <Label text="Выберите товар из списка для обновления" styleClass="info-label"/>
                <GridPane hgap="12" vgap="10">
                    <Label text="ID:" GridPane.columnIndex="0" GridPane.rowIndex="0"/>
                    <TextField fx:id="updateIdField" editable="false" prefWidth="260"
                               GridPane.columnIndex="1" GridPane.rowIndex="0"/>
                    <Label text="Название:" GridPane.columnIndex="0" GridPane.rowIndex="1"/>
                    <TextField fx:id="updateNameField" prefWidth="260"
                               GridPane.columnIndex="1" GridPane.rowIndex="1"/>
                    <Label text="Артикул:" GridPane.columnIndex="0" GridPane.rowIndex="2"/>
                    <TextField fx:id="updateArticleField" prefWidth="260"
                               GridPane.columnIndex="1" GridPane.rowIndex="2"/>
                    <Label text="Цена:" GridPane.columnIndex="0" GridPane.rowIndex="3"/>
                    <TextField fx:id="updatePriceField" prefWidth="260"
                               GridPane.columnIndex="1" GridPane.rowIndex="3"/>
                </GridPane>
                <Button text="Обновить товар" styleClass="btn-primary" onAction="#handleUpdate"/>
                <Label fx:id="updateFormError" styleClass="error-label"/>
            </VBox>
        </Tab>
    </TabPane>
</VBox>
