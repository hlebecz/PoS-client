<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<VBox xmlns="http://javafx.com/javafx/21"
      xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="kurs.client.ui.StockController"
      spacing="16" fillWidth="true">

    <Label text="Остатки товаров" styleClass="page-title"/>

    <TabPane fx:id="tabPane" tabClosingPolicy="UNAVAILABLE" VBox.vgrow="ALWAYS">
        <Tab fx:id="listTab" text="Список">
            <VBox spacing="10">
                <padding><Insets top="14" right="0" bottom="0" left="0"/></padding>
                <HBox spacing="10" alignment="CENTER_LEFT" styleClass="action-toolbar">
                    <Button text="Все остатки" styleClass="btn-primary" onAction="#handleLoadAll"/>
                    <Separator orientation="VERTICAL"/>
                    <Label text="Фильтр по хранилищу:"/>
                    <TextField fx:id="filterLocationField" promptText="Выберите хранилище" editable="false" prefWidth="200"/>
                    <Button text="Выбрать" styleClass="btn-secondary" onAction="#handlePickFilterLocation"/>
                    <Button text="Сбросить" styleClass="btn-secondary" onAction="#handleClearFilter"/>
                </HBox>
                <TableView fx:id="stockTable" VBox.vgrow="ALWAYS">
                    <columns>
                        <TableColumn fx:id="colLocName" text="Хранилище"/>
                        <TableColumn fx:id="colProdName" text="Товар"/>
                        <TableColumn fx:id="colArticle" text="Артикул"/>
                        <TableColumn fx:id="colPrice" text="Цена"/>
                        <TableColumn fx:id="colQty" text="Кол-во"/>
                        <TableColumn fx:id="colUpdated" text="Обновлено"/>
                    </columns>
                    <columnResizePolicy>
                        <TableView fx:constant="CONSTRAINED_RESIZE_POLICY"/>
                    </columnResizePolicy>
                </TableView>
            </VBox>
        </Tab>
        <Tab fx:id="updateTab" text="Установить остаток">
            <VBox spacing="14">
                <padding><Insets top="14" right="0" bottom="0" left="0"/></padding>
                <GridPane hgap="12" vgap="10">
                    <Label text="Хранилище:" GridPane.columnIndex="0" GridPane.rowIndex="0"/>
                    <HBox spacing="8" GridPane.columnIndex="1" GridPane.rowIndex="0">
                        <TextField fx:id="setLocField" promptText="Выберите хранилище" editable="false" prefWidth="300"/>
                        <Button text="Выбрать" styleClass="btn-secondary" onAction="#handlePickLocation"/>
                    </HBox>

                    <Label text="Товар:" GridPane.columnIndex="0" GridPane.rowIndex="1"/>
                    <HBox spacing="8" GridPane.columnIndex="1" GridPane.rowIndex="1">
                        <TextField fx:id="setProductField" promptText="Выберите товар" editable="false" prefWidth="300"/>
                        <Button text="Выбрать" styleClass="btn-secondary" onAction="#handlePickProduct"/>
                    </HBox>

                    <Label text="Количество:" GridPane.columnIndex="0" GridPane.rowIndex="2"/>
                    <TextField fx:id="setQtyField" prefWidth="100" GridPane.columnIndex="1" GridPane.rowIndex="2"/>
                </GridPane>
                <Button text="Установить остаток" styleClass="btn-success" onAction="#handleSetStock"/>
                <Label fx:id="stockStatusLabel" styleClass="error-label"/>
            </VBox>
        </Tab>
    </TabPane>
</VBox>
