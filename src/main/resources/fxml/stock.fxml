<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<BorderPane xmlns="http://javafx.com/javafx/21"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="kurs.client.ui.StockController"
            stylesheets="@../css/app.css">
    <padding><Insets top="16" right="16" bottom="16" left="16"/></padding>
    <center>
        <VBox spacing="12">
            <Label text="Остатки товаров" styleClass="section-title"/>
            <HBox spacing="8" alignment="CENTER_LEFT">
                <Button text="Все остатки"    styleClass="btn-primary"   onAction="#handleLoadAll"/>
                <Separator orientation="VERTICAL"/>
                <Label text="Хранилище:"/>
                <TextField fx:id="locationField" promptText="ID хранилища (UUID)" prefWidth="240"/>
                <Button text="По хранилищу" styleClass="btn-secondary" onAction="#handleLoadByLocation"/>
            </HBox>
            <TableView fx:id="stockTable" VBox.vgrow="ALWAYS">
                <columns>
                    <TableColumn fx:id="colLocName"   text="Хранилище"/>
                    <TableColumn fx:id="colProdName"  text="Товар"/>
                    <TableColumn fx:id="colArticle"   text="Артикул"/>
                    <TableColumn fx:id="colPrice"     text="Цена"/>
                    <TableColumn fx:id="colQty"       text="Кол-во"/>
                    <TableColumn fx:id="colUpdated"   text="Обновлено"/>
                </columns>
                <columnResizePolicy><TableView fx:constant="CONSTRAINED_RESIZE_POLICY"/></columnResizePolicy>
            </TableView>
            <Separator/>
            <HBox spacing="8" alignment="CENTER_LEFT">
                <Label text="Хранилище:"/>
                <TextField fx:id="setLocField"  promptText="ID хранилища" prefWidth="200"/>
                <Label text="Товар:"/>
                <TextField fx:id="setProductField" promptText="ID товара"   prefWidth="200"/>
                <Label text="Кол-во:"/>
                <TextField fx:id="setQtyField"  prefWidth="80"/>
                <Button text="Установить" styleClass="btn-success" onAction="#handleSetStock"/>
                <Label fx:id="stockStatusLabel" styleClass="error-label"/>
            </HBox>
        </VBox>
    </center>
</BorderPane>
