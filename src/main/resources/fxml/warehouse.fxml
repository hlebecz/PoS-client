<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<VBox xmlns="http://javafx.com/javafx/21"
      xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="kurs.client.ui.WarehouseController"
      spacing="16" fillWidth="true">

    <Label text="Склады" styleClass="page-title"/>

    <TabPane fx:id="tabPane" tabClosingPolicy="UNAVAILABLE" VBox.vgrow="ALWAYS">
        <Tab text="Список">
            <VBox spacing="10">
                <padding><Insets top="14" right="0" bottom="0" left="0"/></padding>
                <HBox spacing="10" alignment="CENTER_LEFT" styleClass="action-toolbar">
                    <Button text="Обновить" styleClass="btn-primary" onAction="#handleLoad"/>
                    <Separator orientation="VERTICAL"/>
                    <Button text="Изменить" styleClass="btn-warning" onAction="#handleEdit"/>
                    <Button text="Деактивировать" styleClass="btn-danger" onAction="#handleDeactivate"/>
                    <Button text="Активировать" styleClass="btn-success" onAction="#handleActivate"/>
                </HBox>
                <TableView fx:id="whTable" VBox.vgrow="ALWAYS">
                    <columns>
                        <TableColumn fx:id="colWhName"   text="Название"/>
                        <TableColumn fx:id="colWhPhone"  text="Телефон"/>
                        <TableColumn fx:id="colWhActive" text="Активен" maxWidth="80"/>
                    </columns>
                    <columnResizePolicy>
                        <TableView fx:constant="CONSTRAINED_RESIZE_POLICY"/>
                    </columnResizePolicy>
                </TableView>
            </VBox>
        </Tab>
        <Tab text="Создать">
            <VBox spacing="14">
                <padding><Insets top="14" right="0" bottom="0" left="0"/></padding>
                <GridPane hgap="12" vgap="10">
                    <Label text="Название:" GridPane.columnIndex="0" GridPane.rowIndex="0"/>
                    <TextField fx:id="whNameField"  prefWidth="260"
                               GridPane.columnIndex="1" GridPane.rowIndex="0"/>
                    <Label text="Телефон:"  GridPane.columnIndex="0" GridPane.rowIndex="1"/>
                    <TextField fx:id="whPhoneField" prefWidth="260"
                               GridPane.columnIndex="1" GridPane.rowIndex="1"/>
                </GridPane>
                <Button text="Создать склад" styleClass="btn-success" onAction="#handleCreate"/>
                <Label fx:id="whFormError" styleClass="error-label"/>
            </VBox>
        </Tab>
        <Tab text="Обновить">
            <VBox spacing="14">
                <padding><Insets top="14" right="0" bottom="0" left="0"/></padding>
                <Label text="Выберите склад из списка для обновления" styleClass="info-label"/>
                <GridPane hgap="12" vgap="10">
                    <Label text="ID:" GridPane.columnIndex="0" GridPane.rowIndex="0"/>
                    <TextField fx:id="updateIdField" editable="false" prefWidth="260"
                               GridPane.columnIndex="1" GridPane.rowIndex="0"/>
                    <Label text="Название:" GridPane.columnIndex="0" GridPane.rowIndex="1"/>
                    <TextField fx:id="updateNameField" prefWidth="260"
                               GridPane.columnIndex="1" GridPane.rowIndex="1"/>
                    <Label text="Телефон:" GridPane.columnIndex="0" GridPane.rowIndex="2"/>
                    <TextField fx:id="updatePhoneField" prefWidth="260"
                               GridPane.columnIndex="1" GridPane.rowIndex="2"/>
                </GridPane>
                <Button text="Обновить склад" styleClass="btn-primary" onAction="#handleUpdate"/>
                <Label fx:id="updateFormError" styleClass="error-label"/>
            </VBox>
        </Tab>
    </TabPane>
</VBox>
